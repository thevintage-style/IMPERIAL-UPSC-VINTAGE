rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "raksha05jk.rao@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUserProfile(data) {
      return data.uid is string && 
             data.email is string &&
             data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() >= 2;
    }

    function isValidCommunityMessage(data) {
      return data.text is string && 
             data.text.size() < 5000 &&
             data.senderId == request.auth.uid;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // App Config & Meta
    match /settings/appConfig {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system_meta/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public / Shared Collections
    match /upiIds/{id} { allow read: if true; allow write: if isAdmin(); }
    match /plans/{id} { allow read: if true; allow write: if isAdmin(); }
    match /resources/{id} { allow read: if true; allow write: if isAdmin(); }
    match /newsArticles/{id} { 
      allow read: if true; 
      allow create, delete: if isAdmin();
      allow update: if isSignedIn();
    }
    match /videos/{id} { allow read: if true; allow write: if isAdmin(); }
    match /playlists/{id} { allow read: if true; allow write: if isAdmin(); }
    match /discountOffers/{id} { allow read: if true; allow write: if isAdmin(); }
    match /libraryResources/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /resource_hub/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // Support
    match /supportMessages/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
    match /supportChats/{chatId} {
      allow read, update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/supportChats/$(chatId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isSignedIn() && (incoming().senderId == request.auth.uid || isAdmin());
      }
    }

    // User Data
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && incoming().uid == request.auth.uid && isValidUserProfile(incoming());
      allow update: if (isOwner(userId) && incoming().role == existing().role) || isAdmin();

      match /studyLogs/{logId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /syllabus/{topicId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /notes/{noteId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /folders/{folderId} { allow read, write: if isOwner(userId) || isAdmin(); }
      match /journals/{journalId} { allow read, write: if isOwner(userId) || isAdmin(); }
    }

    // Top-level Progress (Used by Syllabus.tsx)
    match /syllabusProgress/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /publicProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Social / Community
    match /communityMessages/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidCommunityMessage(incoming());
      allow update: if isSignedIn() && (
        // Allow reactions
        incoming().diff(existing()).affectedKeys().hasOnly(['reactions']) ||
        // Allow pinning by admin
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['isPinned']))
      );
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
        allow delete: if isAdmin() || (isSignedIn() && resource.data.senderId == request.auth.uid);
      }
    }

    match /community_posts/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['reactions', 'replyCount']) ||
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['isPinned', 'isHighlighted'])) ||
        (isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasAll(['text']))
      );
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      }
    }

    match /resourcePosts/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin() || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }

    // Admin & Peer restricted
    match /reports/{id} { allow create: if isSignedIn(); allow read, write: if isAdmin(); }
    match /blockedUsers/{id} { allow read, write: if isSignedIn() && (incoming().blockerId == request.auth.uid || existing().blockerId == request.auth.uid); }
    match /chatRequests/{id} { 
      allow create: if isSignedIn() && incoming().fromId == request.auth.uid;
      allow read, update: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
    match /peerMessages/{id} {
      allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid || isAdmin());
    }
    match /recentlyViewed/{id} {
      allow read, write: if isSignedIn() && (incoming().userId == request.auth.uid || existing().userId == request.auth.uid);
    }

    // Financial & Logs
    match /transactions/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
    match /auditLogs/{id} { allow read, write: if isAdmin(); }
    match /engagementStats/{id} { allow read, write: if isAdmin(); }
  }
}
